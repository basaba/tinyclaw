{
  "name": "@basaba/tinyclaw",
  "version": "0.1.2",
  "description": "A Lobster workflow runner powered by GitHub Copilot — run, schedule, and orchestrate LLM workflows from the terminal",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./adapters": "./dist/adapters/index.js"
  },
  "bin": {
    "tinyclaw": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-preload.cjs",
    "build:ui": "tsc && node scripts/copy-preload.cjs && vite build",
    "dev": "tsx src/cli.ts",
    "dev:ui": "vite --config vite.config.ts",
    "dev:web": "tsx src/cli.ts web",
    "start": "node dist/cli.js",
    "start:ui": "electron dist/ui/main/index.js",
    "start:web": "node dist/cli.js web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@basaba/lobster": "^2026.516.1",
    "@dagrejs/dagre": "^3.0.0",
    "@github/copilot-sdk": "^0.2.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@types/ws": "^8.18.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "azure-kusto-data": "^7.1.0",
    "dotenv": "^16.4.0",
    "electron": "^35.0.0",
    "ink": "^5.2.1",
    "marked": "^18.0.2",
    "monaco-editor": "^0.55.1",
    "node-cron": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.20.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
