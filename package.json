{
  "name": "@basaba/tinyclaw",
  "version": "0.1.2",
  "description": "A Lobster workflow runner powered by GitHub Copilot — run, schedule, and orchestrate LLM workflows from the terminal",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./adapters": "./dist/adapters/index.js"
  },
  "bin": {
    "tinyclaw": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@basaba/lobster": "^2026.508.3",
    "@dagrejs/dagre": "^3.0.0",
    "@github/copilot-sdk": "^0.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.0",
    "ink": "^5.2.1",
    "marked": "^18.0.2",
    "node-cron": "^3.0.3",
    "react": "^18.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
